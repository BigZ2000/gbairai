# ──────────────────────────────────────────────────────────────────────────────
# Variables de PRODUCTION (Option A) — lues par docker-compose.prod.yml.
# Sur le serveur :  cp .env.prod.example .env   puis renseigner ci-dessous.
# NE JAMAIS committer le fichier .env (il est déjà gitignored).
# Générer un secret :  openssl rand -base64 48
# ──────────────────────────────────────────────────────────────────────────────

# Domaines (DNS IONOS → IP publique de l'EC2)
APP_DOMAIN=gbairai.robotechci.com
API_DOMAIN=api.gbairai.robotechci.com
ACME_EMAIL=admin@robotechci.com

# Base de données (conteneur Postgres en Option A)
POSTGRES_USER=gbairai
POSTGRES_PASSWORD=CHANGER_moi_mot_de_passe_fort
POSTGRES_DB=gbairai

# JWT — secrets forts et DISTINCTS
JWT_SECRET=CHANGER_openssl_rand_base64_48
JWT_REFRESH_SECRET=CHANGER_openssl_rand_base64_48_autre

# Google OAuth (optionnel — laisser vide si non utilisé)
# Redirect URI à déclarer dans Google Cloud :
#   https://api.gbairai.robotechci.com/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# CinetPay (laisser CINETPAY_ENABLED=false tant que non activé)
CINETPAY_ENABLED=false
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_SECRET_KEY=
CINETPAY_MODE=PRODUCTION

# Email (vérification d'inscription) — SMTP IONOS
# MAIL_ENABLED=false → les mails sont juste logués (aucun envoi).
MAIL_ENABLED=true
SMTP_HOST=smtp.ionos.fr
SMTP_PORT=587
SMTP_USER=gbairai.contact@robotechci.com
SMTP_PASS=
SMTP_FROM=Gbairai <gbairai.contact@robotechci.com>
APP_URL=https://gbairai.robotechci.com
